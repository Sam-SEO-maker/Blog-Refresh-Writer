# =============================================================================
# Content Writer — environment template.  Copy to `.env` and fill in your values.
# `.env` is git-ignored: it stays on your machine and is never shared.
#
# New SEO Managers: follow onboarding/01-setup-machine.md (step 7). The shared
# values below (DataForSEO, YourTextGuru) are in the welcome kit the maintainer
# sends you — never posted in a chat, never committed.
# =============================================================================

# --- Shared: DataForSEO (one account for everyone) ---------------------------
# SERP analysis (PAA, competitors). Values provided by the maintainer.
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here

# --- Shared: YourTextGuru (one key for everyone) -----------------------------
# Semantic guides + QC (SOSEO/DSEO). Value provided by the maintainer.
YTG_NEW_API_KEY=your_ytg_key_here

# --- Shared: Google Search Console — NOTHING TO FILL -------------------------
# GSC data for superprof.* properties comes through the shared MCP server
# (auth lives server-side). Non-Superprof sites (e.g. agency clients) use a
# Google service-account file instead — maintainer topic, not needed for a
# Superprof blog:
# GOOGLE_SA_PATH=~/.credentials/google/google-service-account.json

# --- Your site: WordPress REST API -------------------------------------------
# Needed only to PUSH articles to WordPress (audit and generation work without).
# Ask the tech team for your blog's login + Application Password (see
# onboarding/02-onboard-my-site.md, step 3).
#
# The variable names are the labels you wrote in `wp_api_config` in your
# sites/<site-slug>/config/site.json — they must match character for character.
# Convention: site slug upper-cased, `.` and `-` turned into `_`.
#
# Example for superprof.it:
# WP_SUPERPROF_IT_USER=your_wp_login
# WP_SUPERPROF_IT_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- Your site: Google Sheet (optional) --------------------------------------
# Only if you drive /batch and /decide from a Google Sheet. The maintainer
# creates and shares the spreadsheet, then gives you its id. The variable name
# must match `spreadsheet_env` in your site.json.
# SPREADSHEET_ID_<YOUR_SITE>=your_sheet_id_here

# --- Maintainer only (SEO Managers: ignore) ----------------------------------
# NOTION_TOKEN=            # Notion → sites.json sync
# DATAFORSEO_CREDENTIALS_PATH=~/.credentials/dataforseo/credentials.json

# =============================================================================
# Content Writer — environment template.  Copy to `.env` and fill in your values.
# `.env` is git-ignored: it stays on your machine and is never shared.
# New SEO Managers: see onboarding/01-setup-machine.md.
# =============================================================================

# --- Shared: DataForSEO (one account for everyone) ---------------------------
# Provided by the maintainer. Get credentials at https://dataforseo.com/
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here

# --- Shared: Google Search Console -------------------------------------------
# GSC uses a SHARED service account FILE, not env vars. The maintainer gives you
# `google-service-account.json`; place it where your tenant.json `credentials`
# field points. Never commit that file.
# (The lines below are only for the optional OAuth flow — usually left commented.)
# GSC_CLIENT_ID=your_gsc_client_id
# GSC_CLIENT_SECRET=your_gsc_client_secret

# --- Per-tenant: WordPress REST API ------------------------------------------
# Each market has its own WordPress Application Password
# (WP admin > Users > Application Passwords).
#
# Naming convention: WP_<MARKET>_USER / WP_<MARKET>_APP_PASSWORD.
# These exact names must match `wp_api_config` in your
# tenants/<your-id>/config/tenant.json. You only fill in the block for YOUR blog.
#
# Real examples (already onboarded markets):
# WP_SUPERPROF_RESSOURCES_URL=https://www.superprof.fr/ressources/
# WP_SUPERPROF_RESSOURCES_USER=your_wp_username
# WP_SUPERPROF_RESSOURCES_APP_PASSWORD=your_app_password
#
# WP_ENSEIGNA_URL=https://enseigna.fr/
# WP_ENSEIGNA_USER=your_wp_username
# WP_ENSEIGNA_APP_PASSWORD=your_app_password
#
# Template for your market (uncomment and rename <MARKET>):
# WP_<MARKET>_URL=your_wp_blog_url_here
# WP_<MARKET>_USER=your_wp_username_here
# WP_<MARKET>_APP_PASSWORD=your_app_password_here

# --- Shared: scraper configuration -------------------------------------------
SCRAPER_TIMEOUT=30
SCRAPER_RATE_LIMIT_RPM=20

# --- Shared: editorial audit configuration -----------------------------------
EDITORIAL_AUDIT_ENABLED=true
EDITORIAL_AUDIT_BLOCK_THRESHOLD=4

# --- Shared: MCP configuration -----------------------------------------------
USE_PLAYWRIGHT_FALLBACK=true
CACHE_SCRAPED_HTML=true

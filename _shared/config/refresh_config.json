{
  "_comment": "Configuration consolidée pour le workflow refresh/réécriture - archivé",

  "variant": {
    "refresh": {
      "label": "Rafraichissement",
      "code": "refresh",
      "description": "Mise a jour d'un article existant",
      "focus": "mise a jour des informations existantes",
      "preserve_structure": true,
      "update_statistics": true,
      "verify_links": true,
      "check_freshness": true
    }
  },

  "template_selection": {
    "refresh": "refresh_article.md"
  },

  "article_actions": {
    "refresh": {
      "value": "refresh",
      "description": "Actualiser contenu obsolète (>6 mois)"
    },
    "reecriture": {
      "value": "réécriture",
      "description": "Réécriture complète (E-E-A-T, désindexé)"
    }
  },

  "workflow_actions": {
    "refresh": "refresh",
    "update": "mise_a_jour"
  },

  "stale_content_thresholds": {
    "months_threshold": 6,
    "priority_levels": {
      "1": {"min_days": 90, "max_days": 120},
      "2": {"min_days": 120, "max_days": 180},
      "3": {"min_days": 180, "max_days": 270},
      "4": {"min_days": 270, "max_days": 365},
      "5": {"min_days": 365, "max_days": null}
    }
  },

  "freshness_criteria": {
    "up_to_date": {"max_months": 6},
    "needs_check": {"min_months": 6, "max_months": 12},
    "refresh_recommended": {"min_months": 12, "max_months": 18},
    "refresh_priority": {"min_months": 18}
  },

  "refresh_signals": [
    "lastmod ancien (sitemap)",
    "chute de trafic GSC (> 30% sur 3 mois)",
    "position dégradée (> 5 positions perdues)",
    "données obsolètes (statistiques périmées)"
  ],

  "cli_commands": {
    "rewrite_prepare": "seo rewrite prepare --site=[site_id] [url]",
    "rewrite_from_gsc": "seo rewrite from-gsc --site=[site_id] --min-impressions=100 --max-ctr=2",
    "rewrite_batch": "seo rewrite batch --site=[site_id] --urls-file=urls.txt --output-dir=contexts/",
    "sitemap_stale": "seo sitemap stale --site=[site_id] --months=6 --limit=20"
  }
}
